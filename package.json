{
  "name": "@whirlinggizmo/wg-vf",
  "version": "0.1.0",
  "description": "Whirling Gizmo Vignette Framework",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run build:typescript && bun run example:vignette:wasm:build",
    "build:typescript": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "dev": "bun run clean && bun run dev:local",
    "dev:remote": "bun run --parallel example:vignette:wasm:watch example:remote:server:watch example:remote:app:watch",
    "dev:local": "bun run --parallel example:vignette:wasm:watch example:local:watch",
    "example:local:watch": "bun run --watch examples/local-app.ts",
    "example:remote:app:watch": "bun run --watch examples/remote-app.ts",
    "example:remote:server:watch": "bun run --watch examples/remote-server.ts",
    "example:vignette:wasm:build": "cd examples/vignettes/echo-wasm && nim build",
    "example:vignette:wasm:watch": "bun run example:vignette:wasm:build && onchange \"examples/vignettes/echo-wasm/src/**\" -- bun run example:vignette:wasm:build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "onchange": "^7.1.0",
    "typescript": "^5.8.2"
  }
}
