{
  "name": "@whirlinggizmo/wg-vf",
  "version": "0.1.0",
  "description": "Whirling Gizmo Vignette Framework",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "rebuild": "npm run clean && npm run build",
    "check": "tsc --noEmit -p tsconfig.build.json",
    "test": "bun test",
    "test:unit": "bun test test/unit",
    "test:integration": "bun test test/integration",
    "test:integration:local": "bun test test/integration/local",
    "test:integration:remote": "bun test test/integration/remote",
    "clean": "rimraf dist",
    "prepare": "npm run build",
    "dev": "tsc -w -p tsconfig.build.json",
    "example": "npm run example:local",
    "example:remote": "run-p example:vignette:wasm:watch example:remote:server:watch example:remote:app:watch",
    "example:local": "run-p example:vignette:wasm:watch example:local:watch",
    "example:remote:app": "bun run examples/remote-app.ts",
    "example:remote:server": "bun run examples/remote-server.ts",
    "example:local:app": "bun run examples/local-app.ts",
    "example:local:watch": "onchange --initial --kill \"examples/vignettes/echo-wasm/out/echo-vignette*\" \"examples/vignettes/echo-js/**\" -- bun run --watch examples/local-app.ts",
    "example:remote:app:watch": "bun run --watch examples/remote-app.ts",
    "example:remote:server:watch": "onchange --initial --kill \"examples/vignettes/echo-wasm/out/echo-vignette*\" \"examples/vignettes/echo-js/**\" -- bun run --watch examples/remote-server.ts",
    "example:vignette:wasm:build": "cd examples/vignettes/echo-wasm && nim build wasm",
    "example:vignette:wasm:watch": "npm run example:vignette:wasm:build && onchange \"examples/vignettes/echo-wasm/src/**\" -- npm run example:vignette:wasm:build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "npm-run-all": "^4.1.5",
    "onchange": "^7.1.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.2"
  }
}
