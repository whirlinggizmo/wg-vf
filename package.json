{
  "name": "@whirlinggizmo/wg-vf",
  "version": "0.1.0",
  "description": "Whirling Gizmo Vignette Framework",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "rebuild": "npm run clean && npm run build",
    "check": "tsc --noEmit -p tsconfig.build.json",
    "test": "bun test",
    "test:unit": "bun test test/unit",
    "test:wasm:build": "cd test/wasm && for v in counter echo faulty; do nim c -d:emscripten $v.nim || exit 1; done",
    "test:native:build": "cd test/wasm && nim c --app:lib --mm:arc --nimcache:.nimcache_native --out:out/libcounter.so counter.nim",
    "test:wasm": "npm run test:wasm:build && npm run test:native:build && bun test test/wasm",
    "clean": "rimraf dist",
    "prepare": "npm run build",
    "dev": "tsc -w -p tsconfig.build.json",
    "example:server": "bun run examples/remote-server.ts",
    "example:remote": "bun run examples/simple/remote-app.ts",
    "example:local": "bun run examples/simple/local-app.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "npm-run-all": "^4.1.5",
    "onchange": "^7.1.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.2"
  }
}
