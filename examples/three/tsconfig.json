{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "WebWorker"],
    "types": ["node"]
  },
  "include": ["src/**/*.ts"]
}
